# Python
__pycache__/
*.py[cod]
*.pyo
*.egg-info/
*.egg
dist/
build/

# Virtual environments (but NOT env/ — it holds requirements.txt)
.venv/
venv/

# Data — entirely generated by download/processing scripts
data/

# Models — generated by training scripts (top-level only, not src/debass_meta/models/)
/models/
/artifacts/

# Generated outputs
output/
reports/

# Temporary / scratch
tmp/

# Credentials / secrets
.env

# macOS
.DS_Store

# Jupyter
.ipynb_checkpoints/

# IDE / editor
.idea/
.vscode/
*.swp
*.swo
*~

# Claude Code local state (worktrees, local settings)
.claude/

# pytest / coverage
.pytest_cache/
.coverage
htmlcov/

# Fixture cache — adapters write live-fetched responses here.
