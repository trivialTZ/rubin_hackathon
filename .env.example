# Copy to .env and fill in your tokens.
# .env is git-ignored — never commit it.

# --- TNS (Transient Name Server) ---
# Required for: scripts/crossmatch_tns.py
# Get your API key + marker info at https://www.wis-tns.org/user
# marker_type is "user" for personal accounts, "bot" for registered bots
TNS_API_KEY=
TNS_TNS_ID=
TNS_MARKER_NAME=
TNS_MARKER_TYPE=user

# --- Lasair ---
# Optional: enables live Lasair Sherlock queries
# Get token at https://lasair-ztf.lsst.ac.uk/api/
LASAIR_TOKEN=

# --- Phase 2 (not yet active) ---
ANTARES_API_KEY=
GOOGLE_CLOUD_PROJECT=
